# backend/.env
# ── MIGRAÇÃO MySQL → SQLite ──────────────────────────────────────────────────
# Removidas: DATABASE_HOST, DATABASE_PORT, DATABASE_USER, DATABASE_PASSWORD, DATABASE_NAME
# Adicionadas: DATABASE_FILE, DATABASE_ENCRYPTION_KEY
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados SQLite ────────────────────────────────────────────────────
# Caminho relativo à raiz do processo (backend/)
DATABASE_FILE=./database/fiscalsync.db

# Chave de criptografia AES-256 para campos sensíveis (ex: api_key, api_url)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATABASE_ENCRYPTION_KEY=

# ── API Externa (VarejoFácil) ────────────────────────────────────────────────
EXTERNAL_API_BASE_URL=https://mercado.varejofacil.com/api/v1
EXTERNAL_API_TOKEN=

# ── Servidor NestJS ──────────────────────────────────────────────────────────
PORT=3000

# ── CORS (preenchido automaticamente pelo setup-network.ts) ─────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
