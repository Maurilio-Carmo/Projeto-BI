{
  "name": "importador-fiscal",
  "version": "1.0.0",
  "description": "FiscalSync - Importador de NF-e e NFC-e",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prestart": "ts-node --project scripts/tsconfig.json scripts/setup-network.ts",
    "start": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "node node_modules/@nestjs/cli/bin/nest.js start --watch --config backend/nest-cli.json --path backend/tsconfig.build.json",
    "start:frontend": "node node_modules/vite/bin/vite.js --config frontend/vite.config.ts --host 0.0.0.0",
    "start:network": "ts-node --project scripts/tsconfig.json scripts/setup-network.ts",
    "start:network:tsx": "tsx scripts/setup-network.ts",
    "prebuild": "ts-node --project scripts/tsconfig.json scripts/setup-network.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "node node_modules/@nestjs/cli/bin/nest.js build --config backend/nest-cli.json --path backend/tsconfig.build.json",
    "build:frontend": "node node_modules/vite/bin/vite.js build --config frontend/vite.config.ts",
    "db:create": "ts-node --project scripts/tsconfig.json scripts/db-create.ts",
    "db:push": "npm run db:create && node node_modules/drizzle-kit/bin.cjs push --config backend/drizzle.config.ts",
    "db:generate": "node node_modules/drizzle-kit/bin.cjs generate --config backend/drizzle.config.ts",
    "db:studio": "node node_modules/drizzle-kit/bin.cjs studio --config backend/drizzle.config.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "concurrently": "^9.0.0",
    "cron": "^4.4.0",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.40.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "mysql2": "^3.6.0",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "vite": "^6.0.0"
  }
}
